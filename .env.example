# Application
APP_NAME=human-context
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
# CORS is enabled automatically when APP_ENV=development (allows http://localhost:3000)

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL + pgvector (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://human_context:human_context@localhost:5433/human_context

# Docker production (docker-compose.prod.yml) — required; set POSTGRES_PASSWORD in .env only
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=test
# Must match your embedding model output size (e.g. OpenAI text-embedding-3-small = 1536)
EMBEDDING_DIMENSIONS=1536

# Redis (broker + result backend for Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Import uploads (stored temporarily for Celery workers)
UPLOAD_DIR=/tmp/human_context_uploads
DEFAULT_USER_EMAIL=default@example.com

# Embeddings: fake (local dev) or openai
EMBEDDING_PROVIDER=fake
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_PARALLEL_BATCHES=4
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1

# JWT authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Flower (Celery dashboard, dev only — optional basic auth)
FLOWER_PORT=5555
# FLOWER_BASIC_AUTH=admin:changeme
