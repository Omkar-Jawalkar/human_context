# Application
APP_NAME=human-context
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Comma-separated browser origins allowed to call the API (required in production).
# Dev default: http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=https://human-context.byomkar.tech

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL + pgvector (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://human_context:human_context@localhost:5433/human_context

# Docker production (docker-compose.prod.yml) — required; set POSTGRES_PASSWORD in .env only
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=test
# Must match your embedding model output size (e.g. OpenAI text-embedding-3-small = 1536)
EMBEDDING_DIMENSIONS=1536

# Redis (broker + result backend for Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Import uploads (stored temporarily for Celery workers)
UPLOAD_DIR=/tmp/human_context_uploads
DEFAULT_USER_EMAIL=default@example.com

# Embeddings: fake (local dev) or openai
EMBEDDING_PROVIDER=fake
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_PARALLEL_BATCHES=4
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1

# JWT authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Caddy (HTTPS reverse proxy — required for docker-compose.prod.yml)
# DNS: create an A record pointing API_DOMAIN at your VPS public IP before first deploy.
API_DOMAIN=api.human-context.byomkar.com
# Optional — any inbox you use (Gmail, etc.). Let's Encrypt only sends cert expiry notices.
# Leave empty if you prefer; HTTPS still works without it.
ACME_EMAIL=

# Production SSH tunnel (scripts/prod-human-context.sh — run: make prod-human-context)
PROD_SSH_HOST=user@your-vps-ip
# POSTGRES_LOCAL_PORT=5432
# REDISINSIGHT_LOCAL_PORT=5540
# FLOWER_LOCAL_PORT=5555

# Postgres / Flower / Redis Insight (localhost on VPS — SSH tunnel only, not public)
# POSTGRES_BIND=127.0.0.1
# POSTGRES_PORT=5432
FLOWER_PORT=5555
# REDISINSIGHT_BIND=127.0.0.1
# REDISINSIGHT_PORT=5540
# FLOWER_BIND=127.0.0.1
# FLOWER_BASIC_AUTH=admin:changeme
